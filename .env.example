# ── Logos Drop — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Codex ────────────────────────────────────────────────────────────
# URL of your local Codex node REST API.
# Default port is 8080. In dev, Vite proxies /codex-api → this address.
# Leave commented out to use the dev proxy (recommended for local dev).
# VITE_CODEX_NODE_URL=http://localhost:8080

# ── Nomos ────────────────────────────────────────────────────────────
# URL of your local Nomos node RPC endpoint.
# VITE_NOMOS_RPC_URL=http://localhost:3001

# ── Waku ─────────────────────────────────────────────────────────────
# Optional: override Waku bootstrap peers (comma-separated multiaddrs).
# Defaults to Waku's public fleet if not set.
# VITE_WAKU_BOOTSTRAP_PEERS=/ip4/1.2.3.4/tcp/30303/p2p/QmFoo,...

# ── Feature flags ────────────────────────────────────────────────────
# Force mock mode even when nodes are online (useful for testing)
# VITE_FORCE_MOCK=true
